# ==========================================================
# КОНФИГУРАЦИЯ RUCHAT MESSEN
# ==========================================================
# Скопируйте этот файл как .env и заполните своими данными
# НЕ коммитьте .env файл в git!

# ----------------------------------------------------------
# TELEGRAM BOT
# ----------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Получите токен у @BotFather в Telegram

# ----------------------------------------------------------
# DEVELOPER ACCESS
# ----------------------------------------------------------
DEV_CODE=your_dev_code_here
# Код для доступа к функциям разработчика в боте

# ----------------------------------------------------------
# ADMIN EMAIL (для жалоб)
# ----------------------------------------------------------
ADMIN_EMAIL=ruchat.official@mail.ru

# ----------------------------------------------------------
# SMTP SETTINGS (для отправки email)
# ----------------------------------------------------------
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=ruchat.official@mail.ru
SMTP_PASS=your_smtp_password_here
# Пароль приложения для SMTP (не от почты, а приложение)

# ----------------------------------------------------------
# FIREBASE CONFIGURATION
# ----------------------------------------------------------
FIREBASE_DB_URL=https://web-messenger-1694a-default-rtdb.europe-west1.firebasedatabase.app
# URL вашей Firebase Realtime Database

# ----------------------------------------------------------
# TURN SERVERS (для аудио/видео звонков)
# ----------------------------------------------------------
# Оставьте пустым для использования публичных серверов
# или укажите свои:
# TURN_URL=your_turn_server_url
# TURN_USERNAME=your_turn_username
# TURN_CREDENTIAL=your_turn_credential
